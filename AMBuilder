def configure_common(sdk, cxx, protobuf_binary):
  common_binary = MMSPlugin.HL2Library(builder, cxx, f"{MMSPlugin.metadata['name']}-common", sdk, static = True)

  if common_binary.compiler.family == 'gcc' or common_binary.compiler.family == 'clang':
    common_binary.compiler.defines += ['_GLIBCXX_USE_CXX11_ABI=0']

  if common_binary.compiler.family == 'clang':
    common_binary.compiler.cxxflags += ['-Wno-register', '-frtti', '-Wno-invalid-offsetof', '-Wno-parentheses']

  common_binary.compiler.cxxincludes += [
      os.path.join(builder.sourcePath, 'src'),
      os.path.join(builder.sourcePath, 'hl2sdk-cs2'),
      os.path.join(builder.sourcePath, 'hl2sdk-cs2', 'public', 'entity2'),
      os.path.join(builder.sourcePath, 'hl2sdk-cs2', 'game', 'server'),
  ]

  common_binary.sources += [
    os.path.join(sdk['path'], 'entity2', 'entityidentity.cpp'),
    os.path.join(sdk['path'], 'entity2', 'entitysystem.cpp'),
    os.path.join(builder.sourcePath, 'src', 'utils', 'schema.cpp'),
    os.path.join(builder.sourcePath, 'src', 'utils', 'gameconfig.cpp'),
  ]

  link_protobuf(common_binary, cxx, protobuf_binary)

  return builder.Add(common_binary).binary

