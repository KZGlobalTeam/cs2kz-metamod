# Main binary
binary = configure_main(sdk_target, sdk, cxx)
# Shared entity2/schema/gameconfig objects for the mode/style binaries
common_binary = configure_common(sdk, cxx, protobuf_binary)
# Mode binaries
ckz_binary = configure_ckz(sdk, cxx, common_binary)
# Style binaries
abh_binary = configure_abh(sdk, cxx, common_binary)
lgj_binary = configure_lgj(sdk, cxx, common_binary)
aud_binary = configure_aud(sdk, cxx, common_binary)

link_protobuf(binary, cxx, protobuf_binary)
link_protobuf(ckz_binary, cxx, protobuf_binary)
link_protobuf(abh_binary, cxx, protobuf_binary)
link_protobuf(lgj_binary, cxx, protobuf_binary)
link_protobuf(aud_binary, cxx, protobuf_binary)

# We have to split nodes here because they will be put into different folders.
nodes = builder.Add(binary)
mode_nodes = builder.Add(ckz_binary)
abh_nodes = builder.Add(abh_binary)
lgj_nodes = builder.Add(lgj_binary)
aud_nodes = builder.Add(aud_binary)

# If we are generating a VS project, make sure to add the modes in, and the build folder for linter.
if builder.options.generator == 'vs':
  binary.sources += ckz_binary.sources
  binary.sources += abh_binary.sources
  binary.sources += lgj_nodes.sources
  binary.sources += aud_nodes.sources
  binary.compiler.cxxincludes += [os.path.join(builder.buildPath, MMSPlugin.metadata['name'], f'{binary.compiler.target.platform}-{cxx.target.arch}')]


MMSPlugin.binaries += [nodes]
MMSPlugin.mode_binaries += [mode_nodes]
MMSPlugin.style_binaries += [abh_nodes, lgj_nodes, aud_nodes]

