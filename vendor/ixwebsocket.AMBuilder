# vim: set sts=2 ts=8 sw=2 tw=99 et ft=python:
# Pre-builds ixwebsocket as a static library using the already-configured MMSPlugin CXX.
# After building, copy the output to vendor/ and commit it:
#   Windows: copy ixwebsocket\windows-x86_64\ixwebsocket.lib  ..\ixwebsocket.lib
#   Linux:   cp ixwebsocket/linux-x86_64/libixwebsocket.a ../libixwebsocket.a
import os

cxx = MMSPlugin.sdk_target.cxx

lib = cxx.StaticLibrary('ixwebsocket')


lib.compiler.cxxincludes += [
  os.path.join(builder.sourcePath, 'vendor', 'ixwebsocket'),
]

if lib.compiler.target.platform == 'windows':
  lib.compiler.cxxincludes += [
    os.path.join(builder.sourcePath, 'vendor', 'mbedtls', 'include'),
    os.path.join(builder.sourcePath, 'vendor', 'mbedtls', 'tf-psa-crypto', 'include'),
    os.path.join(builder.sourcePath, 'vendor', 'mbedtls', 'tf-psa-crypto', 'drivers', 'builtin', 'include'),
  ]
else:
  lib.compiler.defines += ['_GLIBCXX_USE_CXX11_ABI=0']

ws_dir = os.path.join(builder.sourcePath, 'vendor', 'ixwebsocket', 'ixwebsocket')
for file in os.listdir(ws_dir):
  if file.endswith('.cpp'):
    lib.sources.append(os.path.join(ws_dir, file))

builder.Add(lib)

